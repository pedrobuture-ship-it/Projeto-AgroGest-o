CREATE TABLE public.animais (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  fazenda_id uuid,
  lote_id uuid,
  brinco text NOT NULL,
  nome text,
  raca text,
  sexo character CHECK (sexo = ANY (ARRAY['M'::bpchar, 'F'::bpchar])),
  peso numeric,
  status text DEFAULT 'saudavel'::text CHECK (status = ANY (ARRAY['saudavel'::text, 'prenha'::text, 'tratamento'::text, 'morto'::text, 'vendido'::text])),
  nascimento date,
  observacoes text,
  created_at timestamp with time zone DEFAULT now(),
  updated_at timestamp with time zone DEFAULT now(),
  CONSTRAINT animais_pkey PRIMARY KEY (id),
  CONSTRAINT animais_fazenda_id_fkey FOREIGN KEY (fazenda_id) REFERENCES public.fazendas(id),
  CONSTRAINT animais_lote_id_fkey FOREIGN KEY (lote_id) REFERENCES public.lotes(id)
);
CREATE TABLE public.convites (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  fazenda_id uuid,
  email text NOT NULL,
  token text NOT NULL UNIQUE,
  usado boolean DEFAULT false,
  created_at timestamp with time zone DEFAULT now(),
  updated_at timestamp with time zone DEFAULT now(),
  CONSTRAINT convites_pkey PRIMARY KEY (id),
  CONSTRAINT convites_fazenda_id_fkey FOREIGN KEY (fazenda_id) REFERENCES public.fazendas(id)
);
CREATE TABLE public.fazendas (
